        "grep_code"
      ],
      "workflow": {
        "visualizeLogPatterns": true,
        "analyzeThreatTrends": true,
        "correlateEvents": true
      }
    },
    "logParsingNormalization": {
      "enabled": true,
      "parsersPath": "../parsers",
      "supportedTools": [
        "search_codebase",
        "search_symbol",
        "read_file",
        "grep_code"
      ],
      "workflow": {
        "validateParserConfigs": true,
        "testLogTransformation": true,
        "checkFormatCompatibility": true
      }
    },
    "datasetAgentMonitoring": {
      "enabled": true,
      "monitorsPath": "../monitors",
      "supportedTools": [
        "read_file",
        "run_in_terminal",
        "get_terminal_output"
      ],
      "workflow": {
        "executeMonitorScripts": true,
        "validatePythonDependencies": true,
        "testLogGeneration": true
      }
    },
    "automatedResponsePlaybooks": {
      "enabled": true,
      "workflowsPath": "../workflows/community",
      "supportedTools": [
